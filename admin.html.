<!DOCTYPE html>
<html lang="ht">
<head>
  <meta charset="UTF-8">
  <title>BSS1815 — ADMIN PANEL</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: system-ui, sans-serif; }

    body { background: #050505; color: #f7f2ec; display: flex; min-height: 100vh; }

    .sidebar {
      width: 260px; background: #050505; border-right: 1px solid #2b2b2b;
      padding: 20px 18px; display: flex; flex-direction: column; gap: 18px;
    }

    .brand-title { font-size: 20px; font-weight: 800; letter-spacing: 2px; color: #ff9b3b; text-transform: uppercase; }
    .brand-sub { font-size: 11px; text-transform: uppercase; color: #b3b3b3; }

    .koukou-logo img {
      width: 120px; border-radius: 10px; border: 1px solid #ff9b3b55; margin: 10px 0 15px;
    }

    .nav-title { font-size: 11px; text-transform: uppercase; color: #777; margin-top: 10px; margin-bottom: 4px; }

    .nav { display: flex; flex-direction: column; gap: 6px; }
    .nav button {
      width: 100%; text-align: left; padding: 8px 10px; border-radius: 8px;
      border: none; background: transparent; color: #f7f2ec; font-size: 13px;
      cursor: pointer; transition: 0.15s;
    }
    .nav button:hover { background: #1b1b1b; }
    .nav button.active {
      background: linear-gradient(90deg, #ff9b3b, #ff6a00); color: #050505; font-weight: 600;
    }

    .logout-btn { margin-top: auto; padding-top: 10px; border-top: 1px solid #2b2b2b; }
    .logout-btn button {
      width: 100%; padding: 8px 10px; border-radius: 8px; border: 1px solid #ff3b3b;
      background: transparent; color: #ff3b3b; font-size: 13px; cursor: pointer; transition: 0.15s;
    }
    .logout-btn button:hover { background: #ff3b3b; color: #050505; }

    .main { flex: 1; display: flex; flex-direction: column; background: radial-gradient(circle at top left, #ff9b3b11, #050505 55%); }
    .topbar {
      padding: 14px 22px; border-bottom: 1px solid #2b2b2b;
      display: flex; align-items: center; justify-content: space-between;
    }
    .top-title { font-size: 16px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
    .top-role {
      font-size: 12px; text-transform: uppercase; color: #ff9b3b;
      border: 1px solid #ff9b3b55; padding: 4px 10px; border-radius: 999px;
    }

    .content { padding: 18px 22px 26px; overflow-y: auto; }
    .section { display: none; animation: fadeIn 0.2s ease-out; }
    .section.active { display: block; }

    .card-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px; margin-top: 10px;
    }

    .card {
      background: #101010; border-radius: 12px; border: 1px solid #2b2b2b;
      padding: 12px 12px 10px;
    }

    .contact-flyout {
      position: fixed; right: 20px; bottom: 30px;
      display: flex; flex-direction: column; gap: 10px; z-index: 9999;
    }
    .contact-flyout button {
      background: #25D366; color: #050505; border: none;
      padding: 10px 14px; border-radius: 8px; font-weight: 600;
      cursor: pointer; transition: 0.2s;
    }
    #twilioBtn { background: #ff3b3b; color: #fff; }
    .contact-flyout button:hover { opacity: 0.85; }

    .flyout {
      position: fixed; right: -320px; top: 0; width: 300px; height: 100vh;
      background: #101010; border-left: 1px solid #ff9b3b55;
      padding: 20px; transition: 0.3s ease; z-index: 9998;
    }
    .flyout.open { right: 0; }

    .flyout input, .flyout textarea {
      width: 100%; margin-top: 10px; padding: 8px;
      border-radius: 6px; border: 1px solid #333;
      background: #000; color: #fff;
    }
    .flyout button {
      margin-top: 12px; width: 100%; padding: 10px;
      background: #ff9b3b; border: none; border-radius: 6px;
      font-weight: 600; cursor: pointer;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
  </style>

  <script type="module" src="firebase-config.js"></script>
  <script type="module" src="admin.js"></script>
</head>

<body>

  <aside class="sidebar">
    <div class="brand">
      <div class="brand-title">BSS1815</div>
      <div class="brand-sub">ADMIN PANEL OFISYÈL</div>
    </div>

    <div class="koukou-logo">
      <img src="koukou-logo.png" alt="KOUKOU LOGO">
    </div>

    <div class="nav-title">NAVIGASYON</div>
    <div class="nav">
      <button class="nav-btn active" data-target="dashboard">Dashboard</button>
      <button class="nav-btn" data-target="admins">Admins</button>
      <button class="nav-btn" data-target="videos">Videos</button>
      <button class="nav-btn" data-target="musicians">Musicians</button>
      <button class="nav-btn" data-target="leaders">Leaders</button>
      <button class="nav-btn" data-target="bands">Bands</button>
      <button class="nav-btn" data-target="finances">Finances</button>
      <button class="nav-btn" data-target="settings">Settings</button>
    </div>

    <div class="logout-btn">
      <button id="logoutBtn">Dekonekte</button>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <div class="top-title">BSS1815 — <span id="pageTitle">Dashboard</span></div>
      <div class="top-role" id="roleChip">...</div>
    </header>

    <section class="content">

      <div class="section active" id="section-dashboard">
        <h2>Dashboard</h2>
        <p>Rezime rapid sou sa k ap pase nan BSS1815.</p>
      </div>

      <div class="section" id="section-admins">
        <h2>Admins</h2>
        <div id="adminsList" class="card-grid"></div>
      </div>

      <div class="section" id="section-musicians">
        <h2>Musicians</h2>
        <div id="musiciansList" class="card-grid"></div>
      </div>

      <div class="section" id="section-leaders">
        <h2>Leaders</h2>
        <div id="leadersList" class="card-grid"></div>
      </div>

      <div class="section" id="section-settings">
        <h2>Settings</h2>
        <div class="card"><h3>Wòl ou</h3><span id="settingsRole">—</span></div>
      </div>

    </section>
  </main>

  <div class="contact-flyout">
    <button id="whatsappBtn">WhatsApp</button>
    <button id="twilioBtn">SMS</button>
  </div>

  <div id="flyoutPanel" class="flyout">
    <h3 id="flyoutTitle">Kontakte</h3>
    <input id="flyoutNumber" type="text" placeholder="Nimewo WhatsApp / SMS">
    <textarea id="flyoutMessage" placeholder="Ekri mesaj la..."></textarea>
    <button id="sendMessageBtn">Voye</button>
  </div>

  <script>
    const navButtons = document.querySelectorAll(".nav-btn");
    const sections = document.querySelectorAll(".section");
    const pageTitle = document.getElementById("pageTitle");

    navButtons.forEach(btn => {
      btn.addEventListener("click", () => {
        navButtons.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");

        const target = btn.dataset.target;
        pageTitle.textContent = target.charAt(0).toUpperCase() + target.slice(1);

        sections.forEach(sec => sec.classList.remove("active"));
        document.getElementById("section-" + target).classList.add("active");
      });
    });

    const flyout = document.getElementById("flyoutPanel");
    const flyoutTitle = document.getElementById("flyoutTitle");

    document.getElementById("whatsappBtn").onclick = () => {
      flyoutTitle.textContent = "WhatsApp";
      flyout.classList.add("open");
    };

    document.getElementById("twilioBtn").onclick = () => {
      flyoutTitle.textContent = "Twilio SMS";
      flyout.classList.add("open");
    };

    document.addEventListener("keydown", e => {
      if (e.key === "Escape") flyout.classList.remove("open");
    });
  </script>

</body>
</html>
